# ==============================

# ContextKeeper Environment Variables

# Copy this file to `.env` and fill in real values.

# ==============================

# ---- AI MODEL CONFIGURATION ----

# Groq API key used for LLM calls

GROQ_API_KEY=your_groq_api_key_here

# Fast model (cheap / fast tasks)

GROQ_FAST_MODEL=llama3-8b-8192

# Smart model (complex reasoning)

GROQ_SMART_MODEL=llama3-70b-8192

# ---- VECTOR DATABASE (RAG) ----

# Qdrant vector DB URL

QDRANT_URL=http://localhost:6333

# Qdrant API key (leave blank for local dev)

QDRANT_API_KEY=your_qdrant_api_key

# ---- DATABASE ----

# SQLite example

DATABASE_URL=sqlite:///contextkeeper.db

# Example for Postgres (production)

# DATABASE_URL=postgresql://user:password@localhost/contextkeeper

# ---- SERVER ----

BACKEND_PORT=8000
